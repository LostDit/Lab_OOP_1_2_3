#include "Field.h"

Field::Field(int width, int height, const int* tiles, int zeroRow, int zeroCol)
    : width_(width), height_(height), zeroRow_(zeroRow), zeroCol_(zeroCol)
{
    size_t total = static_cast<size_t>(width) * height;
    tiles_ = new int[total];
    std::copy(tiles, tiles + total, tiles_);
}

Field::Field(size_t size)
    : width_(static_cast<int>(size)),
      height_(static_cast<int>(size)),
      zeroRow_(static_cast<int>(size) - 1),
      zeroCol_(static_cast<int>(size) - 1)
{
    tiles_ = new int[size * size];
    generateStartField(size);
}

Field::~Field() {
    delete[] tiles_;
}

void Field::generateStartField(size_t size) {
    // При необходимости перераспределяем память, если размер изменился
    if (static_cast<size_t>(width_) != size || static_cast<size_t>(height_) != size) {
        delete[] tiles_;
        width_ = height_ = static_cast<int>(size);
        tiles_ = new int[size * size];
        zeroRow_ = static_cast<int>(size) - 1;
        zeroCol_ = static_cast<int>(size) - 1;
    }

    size_t total = size * size;
    for (size_t i = 0; i < total - 1; ++i)
        tiles_[i] = static_cast<int>(i + 1);
    tiles_[total - 1] = 0;
}

bool Field::operator==(const Field& other) const {
    if (width_ != other.width_ || height_ != other.height_)
        return false;
    if (zeroRow_ != other.zeroRow_ || zeroCol_ != other.zeroCol_)
        return false;

    size_t total = static_cast<size_t>(width_) * height_;
    for (size_t i = 0; i < total; ++i)
        if (tiles_[i] != other.tiles_[i])
            return false;
    return true;
}

bool Field::operator!=(const Field& other) const {
    return !(*this == other);
}